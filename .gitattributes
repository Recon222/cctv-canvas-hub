# Normalize line endings to LF in the repo and in the working tree on every
# platform. Without this, core.autocrlf=true (the Windows default) makes files
# the debug build regenerates on launch — notably src/lib/bindings.ts, re-exported
# on every `tauri dev` — show up as modified with EOL-only (LF<->CRLF) diffs,
# dirtying the tree after a smoke-test run. eol=lf keeps the working copy LF so
# a regenerated file matches the index and the tree stays clean.
* text=auto eol=lf

# Generated by the debug build (tauri-specta) on every launch. Pin LF explicitly.
src/lib/bindings.ts text eol=lf

# Binary assets — never apply text/EOL conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.mp4 binary
*.wasm binary
